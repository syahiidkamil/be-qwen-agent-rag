# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Node — this is a Python repo, but a stray `npm install` run from
# here would otherwise dump 100k+ tracked files into the working tree.
# Belt-and-braces ignore in case a tool's cwd drifts.
node_modules/
package.json
package-lock.json

# Virtualenv
.venv/
venv/
env/
ENV/

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Environment
.env
.env.*
!.env.example

# Testing & coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Type checkers & linters
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/

# Editor
.idea/
*.swp
*.swo

# Qwen-Agent / DocParser cache (created at runtime by qwen-agent tools)
workspace/

# Claude Code local state (worktrees, settings)
.claude/
