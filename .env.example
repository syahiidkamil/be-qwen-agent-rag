# ============================================================
# CORS — comma-separated list of frontend origins
# (add your Vercel preview + prod URLs here when deploying)
# ============================================================
CORS_ORIGINS=http://localhost:5181

# ============================================================
# Qwen / DashScope (Alibaba Cloud Model Studio - International)
# Console: https://modelstudio.console.alibabacloud.com/
# Models follow Qwen-Agent docs (qwen3-max family). The free-quota
# qwen3.5-122b-a10b works for prototype; switch to qwen-max-latest
# for production stability.
# In code, also set generate_cfg.use_raw_api=True for qwen3-max series
# (per configuration.md) — not an env var, lives in your llm_cfg.
# ============================================================
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

QWEN_CHAT_MODEL=qwen3.5-122b-a10b
QWEN_EMBEDDING_MODEL=text-embedding-v3
QWEN_MAX_INPUT_TOKENS=90000

# ============================================================
# Supabase
# From: Supabase Dashboard -> Settings -> API
#   SUPABASE_URL          = Project URL
#   SUPABASE_SECRET_KEY   = sb_secret_...     (BACKEND ONLY — bypasses RLS)
#
# Auth: the backend verifies session JWTs against the project's JWKS at
#   {SUPABASE_URL}/auth/v1/.well-known/jwks.json
# New Supabase projects use asymmetric JWT Signing Keys (ES256). Nothing
# to paste — JWKS is fetched at request time and cached.
#
# SUPABASE_JWT_SECRET (optional, legacy HS256 fallback):
#   Only set this if your project still uses the Legacy JWT Secret
#   (Settings -> API -> JWT Keys -> "Legacy JWT Secret" tab). For projects
#   on JWT Signing Keys, leave it empty — JWKS verification handles ES256.
#   Do NOT paste a JWT (eyJ...) or a Key ID (kid) here; it must be the
#   raw shared secret string from the Legacy JWT Secret tab.
#
# DATABASE_URL: Settings -> Database -> Connection string -> Session pooler (5432).
# Used for SQLAlchemy / asyncpg / pgvector. Replace YOUR-DB-PASSWORD.
# ============================================================
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SECRET_KEY=
SUPABASE_JWT_SECRET=
DATABASE_URL=postgresql://postgres.YOUR-PROJECT-REF:YOUR-DB-PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# Private Storage bucket for uploaded knowledgebase files (create in dashboard).
SUPABASE_STORAGE_BUCKET=knowledgebase-docs
